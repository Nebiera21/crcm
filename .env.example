# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=crcm
POSTGRES_USER=crcm_user
POSTGRES_PASSWORD=changeme

# Async DSN for SQLAlchemy (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://crcm_user:changeme@postgres:5432/crcm

# Redis
REDIS_URL=redis://redis:6379/0

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_32_char_random_string_here

# Fernet key — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change_me_generate_with_fernet_generate_key

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# First admin (created automatically on first startup if no users exist)
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_EMAIL=admin@localhost
FIRST_ADMIN_PASSWORD=changeme
